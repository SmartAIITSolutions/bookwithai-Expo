{
  "expo": {
    "name": "Book With AI",
    "slug": "bookwithai-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bwa-logo.png",
    "scheme": "bookwithai",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "app.bookwithai.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "bookwithai.app",
              "pathPrefix": "/book"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "ios": {
      "bundleIdentifier": "app.bookwithai.app",
      "associatedDomains": [
        "applinks:bookwithai.app"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/bwa-logo.png",
          "imageWidth": 120
        }
      ],
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Book With AI needs camera access to scan salon QR codes.",
          "microphonePermission": false
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.app.bookwithai.app",
          "enableGooglePay": true
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Book With AI needs calendar access to add your appointments."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Book With AI uses Face ID to keep your account secure."
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/bwa-logo.png",
          "color": "#5B2EFF"
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "09a191e6-4d32-4ef9-9fba-8a9e1eac2213"
      }
    },
    "owner": "bookwithai"
  }
}
